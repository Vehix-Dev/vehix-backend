# Database Configuration
POSTGRES_DB=parkingdb
POSTGRES_USER=parkinguser
POSTGRES_PASSWORD=strongpassword
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Redis Configuration
REDIS_URL=redis://redis:6379/1

# Django Configuration
SECRET_KEY=your-secret-key-here
DEBUG=True

# Pesapal Payment Configuration (REQUIRED FOR DEPOSITS)
# Get these from your Pesapal merchant account: https://pay.pesapal.com/
PESAPAL_URL=https://pay.pesapal.com/v3
PESAPAL_CONSUMER_KEY=your-pesapal-consumer-key
PESAPAL_CONSUMER_SECRET=your-pesapal-consumer-secret
PESAPAL_IPN_ID=your-pesapal-ipn-id

# For testing, you can use Pesapal sandbox:
# PESAPAL_URL=https://cybqa.pesapal.com/pesapalv3
